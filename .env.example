# Copy this to .env and fill your keys

# OpenAI (optional - only if using provider: "openai" in llm_config.json)
OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: custom endpoint

# Anthropic (optional - only if using provider: "anthropic" in llm_config.json)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Redis (optional - for production session storage)
REDIS_URL=redis://localhost:6379
