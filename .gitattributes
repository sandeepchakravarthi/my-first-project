# Force Python as primary language
*.py linguist-language=Python

# Exclude frontend folder from language stats
frontend/ linguist-vendored=true

# Exclude HTML and other web files from language stats
*.html linguist-vendored=true
*.htm linguist-vendored=true
*.ts linguist-vendored=true
*.tsx linguist-vendored=true
*.css linguist-vendored=true
*.js linguist-vendored=true

# Mark config/docs as non-code
*.md linguist-documentation
*.json linguist-data
*.yaml linguist-data
*.yml linguist-data
